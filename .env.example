# ==============================================================================
# SECURE REPO CONFIGURATION VARIABLES
# Rename this file to `.env` (or copy to backend/.env and frontend/.env respectively)
# ==============================================================================

# ------------------------------------------------------------------------------
# BACKEND ENVIRONMENT VARIABLES (backend/.env)
# ------------------------------------------------------------------------------
PORT=8000
HOST=0.0.0.0

# Optional GitHub Token to bypass public API rate limits (not strictly required if cloning via git)
GITHUB_TOKEN=your_github_token_optional

# Google Gemini API key for explaining findings (leave blank to run in mock explanation mode)
GEMINI_API_KEY=your_gemini_api_key

# Firebase Admin SDK Configuration
# If these are left blank, SecureRepo will run using a local JSON database (backend/mock_db.json)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="your_private_key"

# CORS configuration
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# FRONTEND ENVIRONMENT VARIABLES (frontend/.env)
# ------------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# Firebase Client Configuration (used for Auth and database client if wanted)
# If left blank, frontend will run in Mock Authentication mode
VITE_FIREBASE_API_KEY=your_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
